# ===========================================
# EXCURSIONISTAS API - ENVIRONMENT VARIABLES
# ===========================================
# Copiar este archivo como .env y configurar los valores reales

# ===== DATABASE CONFIGURATION =====
# Database provider: "Sqlite" or "PostgreSql"
DATABASE_PROVIDER=Sqlite

# SQLite configuration (for development/testing)
SQLITE_CONNECTION_STRING=Data Source=excursionistas.db

# PostgreSQL configuration (for production)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=excursionistas_db
POSTGRES_USER=excursionistas_user
POSTGRES_PASSWORD=YourSecurePassword123!

# ===== API CONFIGURATION =====
API_PORT=5000
API_HTTPS_PORT=5001
ASPNETCORE_ENVIRONMENT=Development

# ===== CORS CONFIGURATION =====
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:5173

# ===== LOGGING CONFIGURATION =====
LOG_LEVEL=Information
ENABLE_SENSITIVE_DATA_LOGGING=false

# ===== DATA SEEDING =====
ENABLE_DATA_SEEDING=true
